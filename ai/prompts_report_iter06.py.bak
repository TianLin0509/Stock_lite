"""综合投研报告 Prompt — 精简版：8章 + 四维评分"""

from datetime import datetime, timedelta
from data.tushare_client import to_code6

# ── 风格权重映射 ──────────────────────────────────────────────
STYLE_WEIGHTS = {
    "景气成长": {"wt_f": 30, "wt_e": 25, "wt_t": 20, "wt_c": 25},
    "深度价值": {"wt_f": 45, "wt_e": 20, "wt_t": 15, "wt_c": 20},
    "周期反转": {"wt_f": 25, "wt_e": 30, "wt_t": 15, "wt_c": 30},
    "题材博弈": {"wt_f": 10, "wt_e": 15, "wt_t": 25, "wt_c": 50},
}
DEFAULT_WEIGHTS = {"wt_f": 30, "wt_e": 25, "wt_t": 20, "wt_c": 25}

# ── System Prompt ─────────────────────────────────────────────
REPORT_SYSTEM = """【硬性规则（最高优先级，违反即不合格）】
1. 强制优先级校验：报告生成第一步必须完成「零、风格定位」模块，未输出有效标准化操作评级直接判定生成失败，强制重跑；必须先完成四维评分计算，再基于评分严格映射操作评级，评分与评级不一致直接判定不合格。
2. 排雷清单：第三章第4节必须逐行输出全部8项必查风险检测结果（数据注入中已有计算值，你只需填入并判定），严禁省略
3. 评分区分度：四维评分不允许全部落在6-7分区间，至少1个维度≤4或≥8；同赛道标的综合评分差不得低于0.5分，同赛道至少有1个标的综合评分≥8或≤5，禁止全部集中在中间区间；不同赛道龙头与尾部标的评分差不得低于2分；跨赛道校准规则：消费/医药龙头基本面最高可打10分，金融/周期标的基本面最高不超过8.5分；每个维度打分必须附带1句话依据
4. 证伪条件：驱动逻辑表格的每一行都必须填写"证伪条件"列
5. 操作评级强制要求：必须在「零、风格定位」模块末尾和「五、综合研判与操作建议」模块首条两处输出加粗的标准化5档操作评级，严格遵循映射规则：综合评分≥8→买入，7≤评分<8→增持，5≤评分<7→持有，3≤评分<5→减持，评分<3→卖出，未输出操作评级则判定报告生成失败，强制重跑，严禁遗漏
6. 表述严谨性：禁止使用无量化支撑的模糊词汇，明确模糊词汇黑名单：禁止直接使用"有望、大概率、可能、大概、较为、明显、一定"等所有无量化前缀的定性表述，所有趋势判断必须前置标注对应概率，"大概率"替换为"概率≥70%"，"可能"替换为"概率30%-70%"，"有望"替换为"概率≥60%"，"较为"替换为具体量化差值，"明显"替换为幅度≥对应阈值的量化表述，"一定"替换为对应概率阈值，所有判断必须附带明确概率/阈值/触发条件；全报告全文本自动扫描校验，每出现1个未标注量化依据的模糊表述，自动触发对应段落重写，直到符合要求为止
7. 数据完整性：核心数据缺失时优先使用同类替代数据分析（如融资余额变化替代北向资金、行业一致预期均值替代个股一致预期），无可替代数据需给出定性判断并标注参考依据，禁止仅标注数据缺失不做分析，单模块缺失数据占比不得超过10%
8. 排雷清单完整性要求：第三章第4节排雷清单必须覆盖8类必查风险（退市风险、财务造假风险、大股东占款风险、商誉减值风险、债务违约风险、质押爆仓风险、合规处罚风险、主业停产风险），每类风险必须给出明确判定结论和依据，严禁遗漏
9. 格式校验规则：所有加粗内容必须成对使用**包裹，报告生成完成后必须首先校验所有Markdown格式，若存在未闭合的加粗标签、格式混乱问题，必须自动修正格式后再输出，严禁输出格式错误内容

你是中国顶级A股买方研究员，精通基本面、技术面、资金流和预期差分析。你追求独立判断，所有结论必须有数据支撑。引用数字时必须基于数据注入中的真实数据，缺失数据按规则做替代分析。严禁废话套话，任何判断必须附带具体条件、价位或时间。

Markdown格式：加粗必须成对 **文字**，<<<SCORES>>>块是纯文本标记不加markdown。"""

SUMMARY_SYSTEM = "你是一位投研助理，负责生成执行摘要。"


def build_report_prompt(
    name: str,
    ts_code: str,
    context: dict,
    price_snapshot: str,
    indicators_section: str,
) -> tuple[str, str]:
    """构建综合投研报告 prompt

    Returns: (user_prompt, system_prompt)
    """
    today_str = datetime.now().strftime("%Y年%m月%d日")
    future_end = (datetime.now() + timedelta(days=90)).strftime("%Y年%m月")
    code6 = to_code6(ts_code)
    w = DEFAULT_WEIGHTS

    user_prompt = f"""## 生成模式选择（二选一，未指定默认使用完整模式）
1. **完整模式（默认）**：输出全部8个章节内容，适用于深度投研场景
2. **精简模式**：仅输出「零、风格定位」、「一、预期差分析核心结论」、「二、技术面分析-精确交易策略」3个核心模块，其余模块无需输出，所有表述高度精简，禁止冗余内容

## 分析标的：{name}（{code6}）
## 当前日期：{today_str}

═══════════════ 基本信息 ═══════════════
{context.get('basic_info', '暂无')}

═══════════════ K线与技术指标 ═══════════════
{price_snapshot}

