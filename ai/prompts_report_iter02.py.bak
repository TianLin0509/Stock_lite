"""综合投研报告 Prompt — 精简版：8章 + 四维评分"""

from datetime import datetime, timedelta
from data.tushare_client import to_code6

# ── 风格权重映射 ──────────────────────────────────────────────
STYLE_WEIGHTS = {
    "景气成长": {"wt_f": 30, "wt_e": 25, "wt_t": 20, "wt_c": 25},
    "深度价值": {"wt_f": 45, "wt_e": 20, "wt_t": 15, "wt_c": 20},
    "周期反转": {"wt_f": 25, "wt_e": 30, "wt_t": 15, "wt_c": 30},
    "题材博弈": {"wt_f": 10, "wt_e": 15, "wt_t": 25, "wt_c": 50},
}
DEFAULT_WEIGHTS = {"wt_f": 30, "wt_e": 25, "wt_t": 20, "wt_c": 25}

# ── System Prompt ─────────────────────────────────────────────
REPORT_SYSTEM = """【硬性规则】
1. 排雷清单：第三章第4节必须逐行输出全部9项检测结果（数据注入中已有计算值，你只需填入并判定），严禁省略
2. 评分区分度：四维评分不允许全部落在6-8分区间，至少1个维度≤5或≥8，同赛道标的综合评分差不得低于0.5分
3. 证伪条件：驱动逻辑表格的每一行都必须填写"证伪条件"列
4. 操作评级：必须输出标准化5档操作评级，严格遵循评分与评级映射规则

你是中国顶级A股买方研究员，精通基本面、技术面、资金流和预期差分析。你追求独立判断，所有结论必须有数据支撑。引用数字时必须基于数据注入中的真实数据，缺失数据标注"⚠️数据缺失"。严禁废话套话，任何判断必须附带具体条件、价位或时间。

Markdown格式：加粗必须成对 **文字**，<<<SCORES>>>块是纯文本标记不加markdown。"""

SUMMARY_SYSTEM = "你是一位投研助理，负责生成执行摘要。"


def build_report_prompt(
    name: str,
    ts_code: str,
    context: dict,
    price_snapshot: str,
    indicators_section: str,
) -> tuple[str, str]:
    """构建综合投研报告 prompt

    Returns: (user_prompt, system_prompt)
    """
    today_str = datetime.now().strftime("%Y年%m月%d日")
    future_end = (datetime.now() + timedelta(days=90)).strftime("%Y年%m月")
    code6 = to_code6(ts_code)
    w = DEFAULT_WEIGHTS

    user_prompt = f"""## 分析标的：{name}（{code6}）
## 当前日期：{today_str}

═══════════════ 基本信息 ═══════════════
{context.get('basic_info', '暂无')}

═══════════════ K线与技术指标 ═══════════════
{price_snapshot}

{indicators_section}

═══════════════ 利润表 ═══════════════
{context.get('income', '暂无')[:1500]}

═══════════════ 资产负债表 ═══════════════
{context.get('balance', '暂无')[:1200]}

═══════════════ 现金流量表 ═══════════════
{context.get('cashflow', '暂无')[:1000]}

═══════════════ 核心财务指标 ═══════════════
{context.get('fina_indicator', '暂无')[:1500]}

═══════════════ 主营业务构成 ═══════════════
{context.get('mainbz', '暂无')[:800]}

═══════════════ 杜邦分析 ═══════════════
{context.get('dupont', '暂无')}

═══════════════ 自由现金流 ═══════════════
{context.get('fcf', '暂无')}

═══════════════ 现金转换周期 ═══════════════
{context.get('ccc', '暂无')}

═══════════════ 资金流向（近15日）═══════════════
{context.get('capital', '暂无')[:800]}

═══════════════ 龙虎榜 ═══════════════
{context.get('dragon', '暂无')[:500]}

═══════════════ 北向资金 ═══════════════
{context.get('northbound', '暂无')[:500]}

═══════════════ 融资融券 ═══════════════
{context.get('margin', '暂无')[:500]}

═══════════════ 十大股东 ═══════════════
{context.get('holders', '暂无')[:800]}

═══════════════ 股东增减持 ═══════════════
{context.get('holdertrade', '暂无')[:600]}

═══════════════ 股东人数 ═══════════════
{context.get('holdernumber', '暂无')[:400]}

═══════════════ 股权质押 ═══════════════
{context.get('pledge', '暂无')[:400]}

═══════════════ 基金持仓 ═══════════════
{context.get('fund', '暂无')[:600]}

═══════════════ 限售解禁 ═══════════════
{context.get('share_float', '暂无')[:400]}

═══════════════ 回购 ═══════════════
{context.get('repurchase', '暂无')[:300]}

═══════════════ 大宗交易 ═══════════════
{context.get('block_trade', '暂无')[:400]}

═══════════════ 分红送股 ═══════════════
{context.get('dividend', '暂无')[:400]}

═══════════════ 审计意见 ═══════════════
{context.get('audit', '暂无')[:300]}

═══════════════ 业绩预告/快报 ═══════════════
{context.get('forecast', '暂无')[:400]}
{context.get('express', '暂无')[:400]}

═══════════════ 财报披露日期 ═══════════════
{context.get('disclosure', '暂无')[:300]}

═══════════════ 板块对比 ═══════════════
{context.get('sector', '暂无')[:600]}

═══════════════ 风险快速排查（9项）═══════════════
{context.get('risk_checklist', '未排查')}

---

⚠️ 数据已注入完毕。请联网搜索补充：{name} 近1月卖方研报/目标价、重大公告/新闻、行业景气变化。

请输出以下章节的综合投研报告（全中文）：

### 零、风格定位

1. 将该股归入一类（只选一个）：深度价值 / 景气成长 / 周期反转 / 题材博弈。一句话理由。
2. 基于打标，声明分析权重（四项之和=100%）：

   | 基本面 | 预期差 | 技术面 | 资金面 |
   |--------|--------|--------|--------|
   | __% | __% | __% | __% |

   参考基准：景气成长 30/25/20/25 | 深度价值 45/20/15/20 | 周期反转 25/30/15/30 | 题材博弈 10/15/25/50

---

### 一、预期差分析

1. **核心驱动逻辑**（⚠️证伪条件列不可留空）：
   | 驱动类型 | 具体内容 | 强度 | 证伪条件（若___则失效） |
   |---------|---------|------|---------------------|
   | ... | ... | 强/中/弱 | ... |

2. **一致预期 vs 你的判断**：如有数据做定量对比表；如无标注"⚠️数据缺失"后做定性判断
3. **预期差挖掘**：
   - 🟢 正向超预期（2-3条，含概率估计）
   - 🔴 负向风险（2-3条，含触发条件和影响幅度）
4. **行业景气与板块定位**：景气阶段 + 板块内差异化标签 + 板块退潮能否独立走强
5. **催化事件日历**：未来至{future_end}，表格（时间 | 事件 | 影响 | 确定性）

---

### 二、技术面分析

1. **多周期趋势定位**（月/周/日线）+ 共振判定
2. **K线形态与量价关系**：近期关键形态、上涨日/下跌日量比
3. **关键价格位**：支撑/压力/前高前低/缺口/定增价/解禁成本
4. **精确交易策略**：
   - 短线（1-2周）：入场 / 止损 / 目标 / 盈亏比
   - 中线（1-3月）：入场区间 / 止损 / 目标 / 盈亏比

---

### 三、基本面分析

1. **财务健康体检**：表格（成长性/盈利质量/现金流/偿债安全/资本效率），每项🟢🔴🟡
2. **ROE杜邦拆解**：基于注入数据，标注主驱动因子和趋势方向
3. **资本开支周期**：基于 CAPEX/FCF 数据，定位（投入→爬坡→满产→收获），FCF 拐点预判
4. **排雷清单**（⚠️必须逐项输出，数据注入中已有计算值）：
   基于上方注入的排雷清单数据，对每项检测结果给出一句话点评，重点展开所有🔴项。最后给出综合风险等级（低/中/高）。
5. **竞争力与行业地位**：护城河评估 + 3-5只同行对比表（市值/PE/增速/特色）
6. **估值诊断**：PE/PB历史分位 + 适合该行业的估值方法 + 高估/合理/低估判断

---

### 四、资金面与市场情绪

1. **主力资金动向**：净流入/流出趋势，大单买卖力量对比
2. **北向资金**：持仓变动方向和持续性（如无数据标注"⚠️数据缺失"）
3. **融资融券**：融资余额变动趋势
4. **龙虎榜/大宗交易**：如有数据，解读机构/游资动向和折溢价信号
5. **股东行为**：户数变动 + 产业资本增减持 + 回购进度
6. **解禁压力**：未来3-6月解禁规模、成本 vs 现价
7. **情绪周期定位**：基于上述资金信号综合判断，处于（恐慌→犹豫→认可→乐观→狂热→分歧）哪个阶段
8. **资金面综合判断**：多空力量对比，一句话结论

---

### 五、矛盾检测

找出本次分析中最突出的维度间矛盾（1-3条）。每条格式：
- **矛盾**：A维度显示___，但B维度显示___
- **你的判断**：更相信哪一方，为什么
- **操作含义**：这个矛盾如何影响仓位或策略

如果各维度信号一致无显著矛盾，写"未发现显著矛盾，各维度共振方向为：___"

---

### 六、综合研判与操作建议

1. **标准化操作评级**（强制必填）：
   - 评级选项（仅选其一，加粗输出）：**买入** / **增持** / **持有** / **减持** / **卖出**
   - 评级映射规则：综合评分≥8→买入，7≤评分<8→增持，5≤评分<7→持有，3≤评分<5→减持，评分<3→卖出
   - 100字以内评级核心理由：___

2. **三情景推演**（概率约束：中性35%-55%，乐观与悲观之差≤25pp）：
   | 情景 | 概率 | 触发条件 | 目标价 | 收益空间 |
   |------|------|----------|--------|----------|
   | 乐观 | __% | ... | ... | ... |
   | 中性 | __% | ... | ... | ... |
   | 悲观 | __% | ... | ... | ... |

3. **最终操作建议**：
   - **核心逻辑**（2-3句）
   - **仓位建议**：___%
   - **核心风险**（2条，每条附证伪指标）
   - **策略有效期**

---

### 七、四维评分

评分标准：9-10极优 | 7-8明确正面 | 5-6中性 | 3-4负面 | 1-2严重问题
各维度具体打分阈值：
- 基本面：9-10分=连续3年ROE≥20%且行业排名Top3；7-8分=连续3年ROE≥10%且行业排名Top10；5-6分=业绩平稳无明显增长；3-4分=业绩连续2年下滑；<3分=持续亏损/存在重大合规风险
- 预期差：9-10分=存在2个及以上未被市场充分定价的强驱动逻辑；7-8分=存在1个未被充分定价的强驱动逻辑；5-6分=与市场预期无明显差异；3-4分=市场预期存在明显高估；<3分=核心驱动逻辑已被证伪
- 技术面：9-10分=月/周/日线多周期共振向上+量价完美配合；7-8分=趋势向上且无重大压力位；5-6分=横盘震荡无明确方向；3-4分=破位放量下跌；<3分=长期下跌趋势无任何企稳信号
- 资金面：9-10分=北向、主力、融资三线持续10日以上净流入；7-8分=主力资金持续5日以上净流入；5-6分=资金流无明确趋势；3-4分=主力资金持续5日以上净流出；<3分=北向、主力、融资三线同步持续净流出

否决规则：排雷🔴≥4→基本面≤4 | 破位放量→技术面≤4 | 三线流出→资金面≤4 | 逻辑证伪→预期差≤4

<<<SCORES>>>
基本面: X/10 (置信度: 高/中/低)
预期差: X/10 (置信度: 高/中/低)
技术面: X/10 (置信度: 高/中/低)
资金面: X/10 (置信度: 高/中/低)
---
综合加权: X/10 (= 基本面×{w['wt_f']}% + 预期差×{w['wt_e']}% + 技术面×{w['wt_t']}% + 资金面×{w['wt_c']}%)
短期爆发力: X/10
中线安全垫: X/10
致命缺陷: 有/无 → [如有：哪个维度≤3分]
<<<END_SCORES>>>

---

### 八、局限性

一句话说明本次分析最大的数据盲区和时效性。"""

    return user_prompt, REPORT_SYSTEM


def build_summary_prompt(full_report_text: str, name: str = "", code6: str = "") -> str:
    """从完整报告生成执行摘要"""
    return f"""基于以下投研报告全文，生成执行摘要。严格按格式输出，不加任何其他内容。

## 报告全文
{full_report_text[:8000]}

## 输出格式

**一句话结论**：[评级] {name}（{code6}）—— [30字以内核心逻辑]

| 维度 | 判断 |
|------|------|
| 风格定位 | [类型] |
| 最大看点 | ... |
| 最大风险 | ... |
| 支撑/压力/止损 | ___元 / ___元 / ___元 |
| 仓位/短线窗口/中线关注 | __% / __天 / __月 |

**四维评分**：基本面X | 预期差X | 技术面X | 资金面X → 综合X/10
**排雷**：🔴__项触发 → 风险[低/中/高]
**核心矛盾**：[最关键1条，无则写"各维度共振"]
**关键证伪**：若___则核心逻辑失效"""
